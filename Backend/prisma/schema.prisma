generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://neondb_owner:npg_DEOjMJ6xyUm0@ep-silent-base-a1wdt6dx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
}

model User {
  id           String        @id @default(uuid())
  phone        String?       @unique
  email        String?       @unique
  fullName     String?
  dateOfBirth  DateTime?
  address      String?
  profilePhoto String?
  authProvider String      // "google" | "apple" | "phone"
  createdAt    DateTime      @default(now())
  profile      RiderProfile?
  policies     Policy[]
}

model RiderProfile {
  id                       String   @id @default(uuid())
  userId                   String   @unique
  user                     User     @relation(fields: [userId], references: [id])
  platform                 String   // "zepto" | "blinkit"
  city                     String?
  serviceZone              String   // e.g. "Bengaluru-Koramangala"
  avgDailyIncome           Float
  workingHours             Int?
  workingShiftLabel        String?
  workingTimeSlots         String[] @default([])
  weeklyWorkDays           Int      @default(6)
  zoneRiskScore            Float    @default(0.3)  // seeded from zone history
  platformConnectionStatus String   @default("not_connected") // "not_connected" | "verified" | "not_found"
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Policy {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  status          String   // "active" | "expired" | "pending_payment"
  weekStartDate   DateTime
  weekEndDate     DateTime
  coveragePerDay  Float
  weeklyPremium   Float
  riskSnapshot    Json     // { F, Z, A, composite } at time of purchase
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  claims          Claim[]
}

model Claim {
  id             String   @id @default(uuid())
  policyId       String
  policy         Policy   @relation(fields: [policyId], references: [id])
  triggerType    String   // "rain" | "app_outage" | "zone_closure"
  affectedSlots  Json     // ["S3", "S4"]
  disruptedHours Float
  payoutAmount   Float
  status         String   // "auto_approved" | "pending_review" | "paid"
  createdAt      DateTime @default(now())
}

model DisruptionEvent {
  id          String   @id @default(uuid())
  zone        String
  triggerType String
  startTime   DateTime
  endTime     DateTime?
  dataSnapshot Json    // raw API response that triggered it
}
